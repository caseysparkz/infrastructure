{
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "alpinejs": "^3.15.12",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14"
  },
  "scripts": {
    "dev": "pnpm run build:css:dev && hugo server --disableFastRender --noHTTPCache --disableBrowserError",
    "css:watch": "vite build --mode development --watch",
    "hugo:watch": "hugo server --disableFastRender --noHTTPCache --disableBrowserError",
    "build:css": "vite build --mode production",
    "build:css:dev": "vite build --mode development --no-watch",
    "build": "pnpm run build:css && hugo --minify --gc --cleanDestinationDir",
    "rebuild": "find static/css/ -name 'main.*.css' -delete 2>/dev/null || true && pnpm run build:css:dev",
    "test": "hugo"
  }
}
