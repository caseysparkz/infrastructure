# shellcheck    disable=SC2034
# Author:       Casey Sparks
# Date:         March 23, 2026
# Description:  Variables to be consumed by Dagger runtime.
# Notes:        !!!THIS FILE IS COMMITTED TO SCM!!!
#               DO NOT PUT SECRET VALUES IN THIS FILE.
#               Reference existing environment variables with the 'env://' prefix.
#               Reference AWS Secrets Manager secrets with the 'aws+sm://' prefix.
AWS_ACCESS_KEY_ID='env://AWS_ACCESS_KEY_ID'
AWS_SECRET_ACCESS='env://AWS_SECRET_ACCESS'
AWS_SESSION_TOKEN='env://AWS_SESSION_TOKEN'
AWS_REGION='us-west-2' # Default value set by dagger runtime.
INFRACOST_API_KEY='aws+sm://infracost/api_key'
